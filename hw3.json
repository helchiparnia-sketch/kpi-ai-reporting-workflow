    {
      "parameters": {
        "jsCode": "// 1. Grab the current month and the previous month from the list\nconst current = items[items.length - 1].json;\nconst previous = items[items.length - 2] ? items[items.length - 2].json : null;\n\n// Handle the typo in the spreadsheet column header (\"mesaage\")\nconst userMessage = current.message || current.mesaage || \"\";\n\n// 2. VALIDATION CHECK (Rubric Requirement)\n// If the email is missing, mark it as Invalid and stop doing math.\nif (!current.email || current.email.toString().trim() === \"\") {\n    return [{\n        json: {\n            status: \"Invalid\",\n            reason: \"Missing email address. Cannot process.\",\n            message: userMessage\n        }\n    }];\n}\n\n// 3. CALCULATE GROWTH \nconst calcGrowth = (curr, prev) => {\n    // Prevent division by zero\n    if (!prev || prev === 0) return 0; \n    return (((curr - prev) / prev) * 100).toFixed(1);\n};\n\n// 4. RETURN DATA\nreturn [{\n  json: {\n      status: \"Valid\", \n      \n      // Pass the user info for the AI and Email nodes\n      email: current.email,\n      message: userMessage, // AI will use this!\n      \n      // Your KPI data mapping exactly to your sheet headers\n      month: current.Month,\n      revenue: current.Revenue,\n      rev_growth: previous ? calcGrowth(current.Revenue, previous.Revenue) + \"%\" : \"0%\",\n      expenses: current.Expenses,\n      exp_growth: previous ? calcGrowth(current.Expenses, previous.Expenses) + \"%\" : \"0%\",\n      customers: current.Customers,\n      cust_growth: previous ? calcGrowth(current.Customers, previous.Customers) + \"%\" : \"0%\",\n      churn: current.Churn,\n      churn_growth: previous ? calcGrowth(current.Churn, previous.Churn) + \"%\" : \"0%\",\n      arpu: current.ARPU,\n      arpu_growth: previous ? calcGrowth(current.ARPU, previous.ARPU) + \"%\" : \"0%\"\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        48
      ],
      "id": "2c076be4-f555-40fa-8149-53cbd4636588",
